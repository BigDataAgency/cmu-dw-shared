{
  "name": "@cmu-dw/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types and API client for CMU Drinking Water apps",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "types": "./dist/types/index.d.mts"
    },
    "./api-client": {
      "import": "./dist/api-client/index.mjs",
      "types": "./dist/api-client/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist"
  ]
}
